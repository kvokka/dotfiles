{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/master/assets/oh-my-opencode.schema.json",
  // https://github.com/code-yeongyu/oh-my-opencode/blob/master/docs/configurations.md
  "default_run_agent": "sisyphus",
  "team_mode": {
    "enabled": true,
    "max_parallel_members": 4,
    "max_members": 8,
    "tmux_visualization": false
  },
  "telemetry": false,
  "agents": {
    "sisyphus": {
      "model": "openai/gpt-5.6-sol",
      "variant": "high",
      "skills": [
        "github-local-issue-pr"
      ],
      "ultrawork": {
        "model": "openai/gpt-5.6-sol",
        "variant": "max"
      }
    },
    "hephaestus": {
      "model": "openai/gpt-5.6-sol",
      "variant": "medium"
    },
    "oracle": {
      "model": "openai/gpt-5.6-sol",
      "variant": "xhigh"
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.6-luna",
      "variant": "xhigh"
    },
    "librarian": {
      "model": "openai/gpt-5.6-luna",
      "variant": "high"
    },
    "explore": {
      "model": "openai/gpt-5.6-luna",
      "variant": "high"
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.6-luna",
      "variant": "high"
    },
    "prometheus": {
      "model": "openai/gpt-5.6-sol",
      "skills": [
        "github-local-issue-pr"
      ],
      "variant": "xhigh"
    },
    "metis": {
      "model": "openai/gpt-5.6-sol",
      "variant": "high"
    },
    "momus": {
      "model": "openai/gpt-5.6-sol",
      "variant": "xhigh"
    },
    "atlas": {
      "model": "openai/gpt-5.6-sol",
      "variant": "medium"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "openai/gpt-5.6-sol",
      "variant": "high"
    },
    "artistry": {
      "model": "openai/gpt-5.6-sol",
      "variant": "high"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.6-sol",
      "variant": "xhigh"
    },
    "quick": {
      "model": "openai/gpt-5.6-luna",
      "variant": "low"
    },
    "deep": {
      "model": "openai/gpt-5.6-sol",
      "variant": "high"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.6-luna",
      "variant": "max"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.6-sol",
      "variant": "high"
    },
    "writing": {
      "model": "openai/gpt-5.6-sol",
      "variant": "medium"
    }
  },
  "experimental": {
    "aggressive_truncation": true
  },
  "browser_automation_engine": {
    "provider": "agent-browser"
  },
  "background_task": {
    "defaultConcurrency": 10,
    "staleTimeoutMs": 180000,
    "providerConcurrency": {
      "google": 20,
      "anthropic": 3,
      "openai": 20
    },
    "modelConcurrency": {
      // "anthropic/claude-haiku-4-5": 10,
      "openai/gpt-5.6-sol": 10,
      "openai/gpt-5.6-terra": 10,
      "openai/gpt-5.6-luna": 10,
      "openai/gpt-5.5": 10,
      "openai/gpt-5.3-codex": 5
    }
  }
}
