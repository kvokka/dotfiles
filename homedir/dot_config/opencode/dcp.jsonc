{
  "$schema": "https://raw.githubusercontent.com/Opencode-DCP/opencode-dynamic-context-pruning/master/dcp.schema.json",
  "enabled": true,
  "compress": {
    "showCompression": true,
    "modelMaxLimits": {
      "openai/gpt-5.3-codex": 200000,
      "openai/gpt-5.4": 200000,
      "openai/gpt-5.5": 200000,
      "openai/gpt-5.4-mini": 100000,
      "anthropic/claude-sonnet-4.6": "80%",
      "anthropic/claude-opus-4.6": "80%"
    },
    "modelMinLimits": {
      "openai/gpt-5.3-codex": 50000,
      "openai/gpt-5.4": 50000,
      "openai/gpt-5.5": 50000,
      "openai/gpt-5.4-mini": 50000,
      "anthropic/claude-sonnet-4.6": "25%",
      "anthropic/claude-opus-4.6": "25%"
    },
    "protectUserMessages": true
  }
}
