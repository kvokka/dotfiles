{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/master/assets/oh-my-opencode.schema.json",
  // https://github.com/code-yeongyu/oh-my-opencode/blob/master/docs/configurations.md
  "agents": {
    "sisyphus": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "sisyphus-junior": {
      "category": "unspecified-high"
    },
    "librarian": {
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "variant": "low",
      "fallback_models": [
        "openai/gpt-5.4",
        "google/gemini-3.1-pro-preview",
        "gpt-5.3-codex"
      ]
    },
    "explore": {
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "variant": "low",
      "fallback_models": [
        "openai/gpt-5.4",
        "google/gemini-3.1-pro-preview",
        "gpt-5.3-codex"
      ]
    },
    "multimodal-looker": {
      "mode": "subagent",
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "prometheus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "metis": {
      "mode": "subagent",
      "category": "unspecified-high"
    },
    "momus": {
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "atlas": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    }
  },
  "categories": {
    "artistry": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh"
    },
    "quick": {
      "model": "openai/gpt-5.4",
      "variant": "low",
      "fallback_models": [
        "openai/gpt-5.4",
        "google/gemini-3.1-pro-preview"
      ]
    },
    "deep": {
      "model": "openai/gpt-5.3-codex",
      "variant": "high"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "writing": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    }
  },
  "experimental": {
    "aggressive_truncation": true
  },
  "browser_automation_engine": {
    "provider": "agent-browser"
  },
  "background_task": {
    "defaultConcurrency": 10,
    "staleTimeoutMs": 180000,
    "providerConcurrency": {
      "google": 20,
      "anthropic": 3,
      "openai": 10
    },
    "modelConcurrency": {
      "google/gemini-3-flash-preview": 15,
      "google/gemini-3.1-pro-high": 10,
      "google/gemini-3.1-pro-low": 10,
      "anthropic/claude-opus-4-6-thinking": 3,
      "anthropic/claude-sonnet-4-6": 3,
      "anthropic/claude-sonnet-4-5-thinking": 3,
      "anthropic/claude-haiku-4-5": 10,
      "openai/gpt-5.4": 10,
      "openai/gpt-5.3-codex": 3
    }
  }
}
