    "opencode": {
      "whitelist": [
        "big-pickle",
        "minimax-m2.5-free",
        "nemotron-3-super-free"
      ]
    },
    "openai": {
      "models": {
        "gpt-5.5": {
          "limit": {
            "context": 258000,
            "output": 128000
          },
          "name": "GPT 5.5",
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "medium"
          },
          "variants": {
            "medium": {
              "reasoningEffort": "medium"
            },
            "low": {
              "reasoningEffort": "low"
            },
            "high": {
              "reasoningEffort": "high"
            },
            "xhigh": {
              "reasoningEffort": "xhigh"
            }
          },
          "reasoning": true
        }
      },
      "name": "OpenAI",
      "npm": "@ai-sdk/openai",
      "options": {
        "apiKey": "{env:MY_CLI_LLM_PROXY_API_KEY}",
        "baseURL": "{env:MY_CLI_LLM_PROXY_URL}"
      },
      "whitelist": [
        "gpt-5.4",
        "gpt-5.5",
        "gpt-5.4-mini",
        "gpt-image-2",
        "gpt-5.3-codex",
        "gpt-5.3-codex-spark"
      ]
    }
  }
