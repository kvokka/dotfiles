{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent@4.1.1",
    // "@tarquinen/opencode-dcp@v3.1.9",
    "cc-safety-net@0.8.2"
    //  "opencode-websearch-cited"
  ],
  "server": {
    "hostname": "0.0.0.0",
    "mdns": true,
    "cors": [
      "http://localhost:5173"
    ]
  },
  "mcp": {
    "render": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.render.com/mcp",
        "--header",
        "Authorization: Bearer ${RENDER_API_KEY}"
      ],
      "enabled": false,
      "environment": {
        "Authorization": "Bearer ${RENDER_API_KEY}"
      },
    },
    "browserless-docs": {
      "type": "remote",
      "enabled": false,
      "url": "https://browserless-docs.mcp.kapa.ai"
    },
    "oh-my-posh-validator": {
      "type": "remote",
      "enabled": false,
      "url": "https://ohmyposh.dev/api/mcp"
    }
  },
  "formatter": {
    "markdown-formatter": {
      "command": [
        "rumdl",
        "fmt",
        "--fix",
        "$FILE"
      ],
      "extensions": [
        ".md"
      ]
    },
    "ruff-check": {
      "command": [
        "ruff",
        "check",
        "$FILE"
      ],
      "extensions": [
        ".py"
      ]
    },
    "ruff-format": {
      "command": [
        "ruff",
        "format",
        "$FILE"
      ],
      "extensions": [
        ".py"
      ]
    },
    "python-types-checker": {
      "command": [
        "ty",
        "check",
        "$FILE"
      ],
      "extensions": [
        ".py"
      ]
    },
    "biome-check": {
      "command": [
        "biome",
        "check",
        "$FILE"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        "json",
        "css"
      ]
    }
  },
  "agent": {
    "title": {
      "model": "openai/gpt-5.5",
      "thinkingLevel": "high"
    },
    "summary": {
      "model": "openai/gpt-5.5",
      "thinkingLevel": "medium"
    },
    "explore": {
      "model": "openai/gpt-5.5",
      "thinkingLevel": "low"
    },
    // this is used by ALL models for compaction
    "compaction": {
      "model": "openai/gpt-5.5",
      "thinkingLevel": "low"
    },
    "general": {
      "model": "openai/gpt-5.5",
      "thinkingLevel": "high"
    }
  },
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.5",
  "enabled_providers": [
    "opencode",
    "openai",
    // "anthropic"
  ],
