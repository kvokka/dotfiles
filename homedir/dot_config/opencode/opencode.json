{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent@4.16.1",
    // "@tarquinen/opencode-dcp@v3.1.9",
    "cc-safety-net@1.0.6"
    //  "opencode-websearch-cited"
  ],
  "server": {
    "hostname": "0.0.0.0",
    "mdns": true,
    "cors": [
      "http://localhost:5173"
    ]
  },
  "mcp": {
    "render": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.render.com/mcp",
        "--header",
        "Authorization: Bearer ${RENDER_API_KEY}"
      ],
      "enabled": false,
      "environment": {
        "Authorization": "Bearer ${RENDER_API_KEY}"
      },
    },
    "browserless-docs": {
      "type": "remote",
      "enabled": false,
      "url": "https://browserless-docs.mcp.kapa.ai"
    },
    "oh-my-posh-validator": {
      "type": "remote",
      "enabled": false,
      "url": "https://ohmyposh.dev/api/mcp"
    }
  },
  "formatter": {
    "markdown-formatter": {
      "command": [
        "rumdl",
        "fmt",
        "--fix",
        "$FILE"
      ],
      "extensions": [
        ".md"
      ]
    },
    "ruff-check": {
      "command": [
        "ruff",
        "check",
        "$FILE"
      ],
      "extensions": [
        ".py"
      ]
    },
    "ruff-format": {
      "command": [
        "ruff",
        "format",
        "$FILE"
      ],
      "extensions": [
        ".py"
      ]
    },
    "python-types-checker": {
      "command": [
        "ty",
        "check",
        "$FILE"
      ],
      "extensions": [
        ".py"
      ]
    },
    "biome-check": {
      "command": [
        "biome",
        "check",
        "$FILE"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        "json",
        "css"
      ]
    }
  },
  "agent": {
    "title": {
      "model": "openai/gpt-5.5",
      "thinkingLevel": "high"
    },
    "summary": {
      "model": "openai/gpt-5.5",
      "thinkingLevel": "medium"
    },
    "explore": {
      "model": "openai/gpt-5.5",
      "thinkingLevel": "low"
    },
    // this is used by ALL models for compaction
    "compaction": {
      "model": "openai/gpt-5.5",
      "thinkingLevel": "low"
    },
    "general": {
      "model": "openai/gpt-5.5",
      "thinkingLevel": "high"
    }
  },
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.5",
  "enabled_providers": [
    "opencode",
    "openai",
    // "anthropic"
  ],
  "provider": {
    // "anthropic": {
    //   "npm": "@ai-sdk/anthropic",
    //   "options": {
    //     "apiKey": "{env:MY_CLI_LLM_PROXY_API_KEY}",
    //     "baseURL": "{env:MY_CLI_LLM_PROXY_URL}"
    //   },
    // },
    "opencode": {
      // "whitelist": [
      //   "big-pickle",
      //   "minimax-m2.5-free",
      //   "nemotron-3-super-free"
      // ]
    },
    "openai": {
      "name": "OpenAI",
      "npm": "@ai-sdk/openai",
      "options": {
        "apiKey": "{env:MY_CLI_LLM_PROXY_API_KEY}",
        "baseURL": "{env:MY_CLI_LLM_PROXY_URL}"
      },
      "whitelist": [
        "gpt-5.6-sol",
        "gpt-5.6-sol-pro",
        "gpt-5.6-sol-fast",
        "gpt-5.6-terra",
        "gpt-5.6-terra-pro",
        "gpt-5.6-terra-fast",
        "gpt-5.6-luna",
        "gpt-5.6-luna-pro",
        "gpt-5.6-luna-fast",
        "gpt-5.4",
        "gpt-5.5",
        "gpt-5.4-mini",
        "gpt-image-2",
        "gpt-5.3-codex",
        "gpt-5.3-codex-spark"
      ]
    }
  }
}
