{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/master/assets/oh-my-opencode.schema.json",
  // https://github.com/code-yeongyu/oh-my-opencode/blob/master/docs/configurations.md
  "default_run_agent": "sisyphus",
  "agents": {
    "sisyphus": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "ultrawork": {
        "model": "openai/gpt-5.5",
        "variant": "xhigh"
      }
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    },
    "librarian": {
      "model": "openai/gpt-5.4-mini",
      "variant": "high"
    },
    "explore": {
      "model": "openai/gpt-5.4-mini",
      "variant": "medium",
      "fallback_models": [
        "openai/gpt-5.5",
        "openai/gpt-5.3-codex"
      ]
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    },
    "prometheus": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "metis": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "momus": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "atlas": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "artistry": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "quick": {
      "model": "openai/gpt-5.5",
      "variant": "low"
    },
    "deep": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "writing": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    }
  },
  "experimental": {
    "aggressive_truncation": true
  },
  "browser_automation_engine": {
    "provider": "agent-browser"
  },
  "background_task": {
    "defaultConcurrency": 10,
    "staleTimeoutMs": 180000,
    "providerConcurrency": {
      "google": 20,
      "anthropic": 3,
      "openai": 20
    },
    "modelConcurrency": {
      // "google/gemini-3-flash-preview": 15,
      // "google/gemini-3.1-pro-high": 10,
      // "google/gemini-3.1-pro-low": 10,
      // "anthropic/claude-opus-4-6-thinking": 3,
      // "anthropic/claude-sonnet-4-6": 3,
      // "anthropic/claude-sonnet-4-5-thinking": 3,
      // "anthropic/claude-haiku-4-5": 10,
      "openai/gpt-5.4": 10,
      "openai/gpt-5.5": 10,
      "openai/gpt-5.4-mini": 15,
      "openai/gpt-5.3-codex": 5
    }
  }
}
