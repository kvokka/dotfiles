[env]

_.path = ['{{ "{{config_root}}" }}/node_modules/.bin']

[tools]

nodejs = '24.13'
biome = '2.4'
bun = '1.3'

"npm:aicommit2" = "latest"
"npm:agent-browser" = "latest"
"npm:openclaw" = "v2026.3.13"

golang = '1.26'

python = '3.14'
uv = '0.10'
ruff = '0.15'
ty = '0.0.24'
pipx = '1.10'

# it still uses uvx but syntax of mise if twisted
"pipx:onnx-asr" = { version = "v0.11.0", uvx = true, uvx_args = "--python-preference=managed" }
"pipx:parakeet-mlx" = { version = "0.5.1", uvx = true, uvx_args = "--python-preference=managed" }

prek = '0.3'
hadolint = '2.14'
shellcheck = '0.11'
gitleaks = '8.30'
rumdl = '0.1.57' # too often version bumps
vale = '3.13'

just = '1.46'
chezmoi = '2.70'
bat = '0.26'
fzf = '0.67'
fd = '10.3'
jq = '1.8'
yq = '4.52'
ripgrep = '15.1'
direnv = '2.37'
zoxide = '0.9'
gh = '2.88'

oras = '1.3'

oh-my-posh = '29.9'

neovim = '0.11'

# gemini = '0.28'
codex = '0'
opencode = '1.3'

{{- if eq .chezmoi.os "linux" }}
docker-cli = '29.3'
{{- end }}

{{ if not .headless }}
dive = '0.13'
terraform = '1.14'
cosign = '3'
helm = '4'
helm-diff = '3'
{{ end }}

# # # # # # extras
# ruby = '3.4'
# podman = '5.5'
# rust = '1'
# kubectl = '1.31'
# kubeseal = '0.28'
# k9s = '0.40'
# git-cliff = '2.8'

[settings]

{{ if .ephemeral }}
yes = true
{{ end }}

idiomatic_version_file_enable_tools = ["python", "ruby"]


{{- $paths := list }}
{{- $paths = append $paths (joinPath .chezmoi.homeDir "proj/active") }}

{{- if eq .chezmoi.os "linux" }}
{{-   $paths = append $paths "/workspace" -}}
{{- end }}

trusted_config_paths = [{{ if $paths }}
{{- range compact $paths }}
  "{{ . }}",
{{- end }}
{{- end }}
]

[settings.pipx]
uvx = true

[settings.python]
uv_venv_auto = "create|source"
