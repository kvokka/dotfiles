model = "gpt-5.4"
model_reasoning_effort = "high"
approval_policy = "never"
sandbox_mode = "danger-full-access"
web_search_request = true

model_provider = "myproxy"

[model_providers.myproxy]
# Have to use chezmoi interpolation since it does not support it from env var
base_url = "{{ .localLLMProxyUrl }}"

name = "My Proxy for Codex"
wire_api = "responses"

env_key = "MY_CLI_LLM_PROXY_API_KEY"

[history]
persistence = "save-all"

[projects."/workspace"]
trust_level = "trusted"

[tui]
# Send desktop notifications when approvals are required or a turn completes.
# Defaults to false.
notifications = true
status_line = [
  "model-with-reasoning",
  "context-remaining",
  "current-dir",
  "weekly-limit",
]

[notice]
"hide_gpt-5.1-codex-max_migration_prompt" = false
hide_rate_limit_model_nudge = true
hide_full_access_warning = true

[notice.model_migrations]
"gpt-5.2" = "gpt-5.2-codex"

[analytics]
enabled = false

[feedback]
enabled = false

[features]
multi_agent = true
search_tool = true
