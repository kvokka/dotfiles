export EDITOR="code -w"
export HOMEBREW_NO_AUTO_UPDATE=1
export DISABLE_AUTO_UPDATE="true"
export HOMEBREW_NO_ENV_HINTS=1
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"
{{ if eq .chezmoi.os "linux" }}
if [[ -z $DOCKER_SOCK_OWNED && $GITHUB_ACTIONS != "true" && $CI != "true" && -f /.dockerenv && -S /var/run/docker.sock ]]; then
    sudo chown "$(whoami):$(whoami)" /var/run/docker.sock 2>/dev/null || true
    export DOCKER_SOCK_OWNED=1   # prevent repeating in subshells
fi
{{- end }}
export MY_CLI_LLM_PROXY_HOST={{ .localLLMProxyHost }}
export MY_CLI_LLM_PROXY_URL=$MY_CLI_LLM_PROXY_HOST/v1
export AICOMMIT_CONFIG_PATH=$HOME/.config/aicommit2/config.ini
